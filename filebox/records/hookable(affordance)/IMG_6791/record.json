{
  // 版本号。以后如果记录结构升级，可以用这个字段做兼容。
  "schemaVersion": 1,
  // 旧 umbrellas.json 中的顺序。当前用于稳定输出顺序，平时不需要手改。
  "sourceIndex": 48,
  // 手动填写的展示地址。
  "locationText": "",
  // 地址层级。按从大到小填写，例如 ["Tokyo", "Shibuya"]。
  "locationLevels": [
    "Chiba",
    "Chiba City",
    "Inage Ward"
  ],
  // 照片 EXIF 读取到的坐标。地图默认继续使用这里。
  "photoCoordinates": {
    "lat": 35.62766944,
    "lng": 140.109375
  },
  // 如果你想手动覆盖地图坐标，可以填写；没有就保持 null。
  "locationCoordinates": {
    "lat": 35.62763099180057,
    "lng": 140.10929260253906
  },
  // 照片 EXIF 读取到的拍摄时间。
  "photoTime": "2025-10-10T15:52:02+09:00",
  // 如果你想手动覆盖显示时间，可以填写；没有就保持空字符串。
  "time": "",
  // 手动标题。没有就保持空字符串。
  "title": "",
  // 伞的类型，例如 transparent、folding。没有就保持空字符串。
  "umbrellaType": "",
  // 伞的颜色（旧字段，保留兼容，当前展示改用 umbrellaUnits）。
  "umbrellaColor": "",
  // 伞的数量。可填 "1"~"5" 或 "unknown"，空白表示未填。
  "umbrellaCount": "1",
  // 每把伞的属性列表。{ color, colorDetail, kind, status:[], statusOther }，随数量增减。
  "umbrellaUnits": [
    {
      "color": "colored",
      "colorDetail": "black",
      "kind": "long umbrella",
      "status": [
        "fastened"
      ],
      "statusOther": ""
    }
  ],
  // 编辑用的标记颜色（yellow/black/white，空=无标记）。仅编辑模式地图上显示。
  "editFlag": "",
  // 这个标点整体的文字说明（由正文段落合并而来，用于卡片简介）。
  "story": "",
  // 详情页的图文编排顺序。每项是 {"type":"text","text":...} 或 {"type":"photo","file":...}。
  "blocks": [],
  // 这个标点下的媒体列表。第一项通常是主图。
  "media": [
    {
      // 媒体 ID。主图通常和文件夹名一致。
      "id": "IMG_6791",
      // 文件名。文件本体放在当前 record.json 所在文件夹里。
      "file": "IMG_6791.jpeg",
      // 角色。建议使用 primary、detail、illustration。
      "role": "primary",
      // 这张媒体自己的标题。没有就保持空字符串。
      "title": "",
      // 这张媒体自己的拍摄时间。没有就保持空字符串。
      "photoTime": "2025-10-10T15:52:02+09:00",
      // 这张媒体自己的说明文字。
      "story": "",
      // 旧缩略图路径。当前保留给过渡期网站使用，先不要手改。
      "legacyThumb": "filebox/thumbs/filebox__choice__hookable(affordance)__IMG_6791.jpg"
    }
  ]
}
